# Mesna POS Environment Configuration
# Copy this file to .env and modify as needed

# Database Configuration
DATABASE_URL="file:./data/pos.db"

# Server Configuration
PORT=3001
HOST=0.0.0.0

# Voice AI Configuration
ENABLE_VOICE=true
VOICE_MODEL=tiny  # Options: tiny, base, small, medium, large
VOICE_LANGUAGES=en,ur,hi  # English, Urdu, Hindi

# P2P Network Configuration
UDP_PORT=41234
P2P_ENABLED=true
PEER_DISCOVERY_INTERVAL=5000  # milliseconds

# Receipt Configuration
RECEIPT_WIDTH=32  # characters
RECEIPT_LOGO_PATH=./public/receipt-logo.png
RECEIPT_FOOTER_THANKYOU="Thank you for shopping with us!"
RECEIPT_FOOTER_CONTACT="Contact: +1-234-567-8900 | www.example.com"

# Security Configuration
SESSION_SECRET=your-super-secret-session-key-change-in-production
BCRYPT_SALT_ROUNDS=10

# Feature Flags
ENABLE_ADMIN_PANEL=true
ENABLE_SALES_REPORTS=true
ENABLE_INVENTORY_ALERTS=true
ENABLE_DAILY_ZERO_SALE_RESET=false  # Set true to auto-reset daily counters

# Logging
LOG_LEVEL=info  # Options: error, warn, info, debug
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/pos.log

# Backup Configuration
ENABLE_AUTO_BACKUP=false
BACKUP_INTERVAL_HOURS=6
BACKUP_RETENTION_DAYS=30
BACKUP_DIRECTORY=./backups